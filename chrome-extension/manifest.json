{
  "manifest_version": 3,
  "name": "Exam Proctor Capture Agent",
  "description": "Polls instructor commands in the background and captures the active tab when requested.",
  "version": "1.1.0",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://localhost:3000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
